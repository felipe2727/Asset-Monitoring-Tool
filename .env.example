# ── ScrapeBadger (X/Twitter) ─────────────────────────────
# Get free key at: https://scrapebadger.com (1,000 free credits)
SCRAPEBADGER_API_KEY=your_key_here

# ── Firecrawl (full-text article extraction) ─────────────
FIRECRAWL_API_KEY_1=fc-your_key_here
FIRECRAWL_API_KEY_2=fc-your_key_here

# ── OpenAI (GPT-4o-mini for sentiment) ───────────────────
OPENAI_API_KEY=sk-proj-your_key_here

# ── Finnhub (stocks, news, forex — free tier) ────────────
# Get free key at: https://finnhub.io
FINNHUB_API_KEY=

# ── Reddit (no credentials needed — uses public JSON API) ─
REDDIT_USER_AGENT=Sentinel/1.0

# ── Alpha Vantage (RSI, MACD — free tier) ────────────────
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ── FRED (macro data — free) ─────────────────────────────
# Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── Supabase (production DB — free tier) ─────────────────
# Set up at: https://supabase.com
SUPABASE_URL=
SUPABASE_KEY=

# ── Resend (email delivery — free tier) ──────────────────
# Get free key at: https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=sentinel@yourdomain.com
RESEND_TO_EMAIL=your@email.com

# ── Pipeline control ─────────────────────────────────────
RUN_NUMBER=1
FREE_TRIAL_MODE=true
